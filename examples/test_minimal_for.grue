// Minimal test case - just a simple for loop
// Testing if basic for loop compilation works

world {
    room test_room "Test Room" {
        desc: "A test room."

        object test_obj {
            names: ["object", "test"]
            desc: "A test object."
        }
    }
}

fn test_list() {
    for obj in test_room.contents() {
        print("Found object");
    }
}

grammar {
    verb "test" {
        default => test_list()
    }
}

init {
    player.location = test_room;
    print("Test game loaded");
    look_around();
}

fn look_around() {
    print(player.location.desc);
}
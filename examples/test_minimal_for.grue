// Minimal test case focusing on conditional branch with labels
// Specifically testing the pattern that causes the 0x0fc0 crash

world {
    room test_room "Test Room" {
        desc: "A test room."
    }
}

fn test_condition() {
    // This should generate a conditional branch similar to the examine function
    let obj = test_room;
    if obj != test_room {
        print("Different");
    } else {
        print("Same");  // This branch target should create the problematic label
    }
}

grammar {
    verb "test" {
        default => test_condition()
    }
}

init {
    player.location = test_room;
    print("Minimal test loaded");
}

fn look_around() {
    print(player.location.desc);
}